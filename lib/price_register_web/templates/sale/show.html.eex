<nav>
  <div class="request">
    <input type="text" disabled value="<%= @request_path %>" />
  </div>
  <div class="pagination">&nbsp;
  </div>
</nav>

<table>
  <thead>
    <tr>
      <th class="one">Field</th>
      <th>Value</th>
      <th class="note">Note</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <th class="one">UUID</td>
      <td><%= @sale.id %></td>
      <td class="note">Useful for ensuring you're not importing the same sale twice.</td>
    </tr>
    <tr>
      <th class="one">date</td>
      <td><%= @sale.date |> format_date %></td>
      <td class="note"></td>
    </tr>
    <tr>
      <th class="one">price</td>
      <td><%= @sale.price |> format_currency %></td>
      <td class="note">This is stored and returned as an integer in cents, not euros.</td>
    </tr>
    <tr>
      <th class="one">address</td>
      <td><%= @sale.address %></td>
      <td class="note">Exactly as we receive it from the PSRA &mdash; no cleaning, correcting or normalising</td>
    </tr>
    <tr>
      <th class="one">postal_code</td>
      <td><%= @sale.postal_code %></td>
      <td class="note">Only for Dublin properties. Not Eircode</td>
    </tr>
    <tr>
      <th class="one">county</td>
      <td><%= @sale.county %></td>
      <td class="note"></td>
    </tr>
    </tr>
    <tr>
      <th class="one">full_market</td>
      <td><%= @sale.full_market %></td>
      <td class="note">This is inverted from the PSRA's field, and normalised into a boolean.</td>
    </tr>
    <tr>
      <th class="one">vat_inclusive</td>
      <td><%= @sale.vat_inclusive %></td>
      <td class="note">Also inverted from the PSRA's field, and normalised into a boolean.</td>
    </tr>
    <tr>
      <th class="one">description</td>
      <td><%= @sale.description %></td>
      <td class="note">As we receive it from the PSRA.</td>
    </tr>
    <tr>
      <th class="one">size_description</td>
      <td><%= @sale.size_description %></td>
      <td class="note">As above.</td>
    </tr>
  </tbody>
</table>